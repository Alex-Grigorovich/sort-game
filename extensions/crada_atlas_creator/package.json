{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "crada_atlas_creator",
    "version": "3.2.2.1",
    "author": "GGorshenin",
    "editor": ">=3.8.7",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "npx tsc"
    },
    "description": "i18n:crada_atlas_creator.description",
    "main": "./dist/main.js",
    "dependencies": {
        "fs-extra": "^10.0.0"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.7",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "typescript": "^5.8.2"
    },
    "panels": {
        "default": {
            "title": "🎨 Atlas Creator",
            "type": "dockable",
            "main": "dist/panels/default",
            "size": {
                "min-width": 800,
                "min-height": 500,
                "width": 1200,
                "height": 700
            }
        }
    },
    "contributions": {
        "menu": [
            {
                "path": "i18n:menu.panel/Atlas Creator",
                "label": "i18n:Open Panel",
                "message": "open-panel"
            },
            {
                "path": "i18n:menu.develop/crada_atlas_creator",
                "label": "i18n:crada_atlas_creator.send_to_panel",
                "message": "send-to-panel"
            }
        ],
        "messages": {
            "open-panel": {
                "methods": [
                    "openPanel"
                ]
            },
            "send-to-panel": {
                "methods": [
                    "default.hello"
                ]
            }
        }
    }
}